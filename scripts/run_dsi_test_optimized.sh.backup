#!/bin/bash
#!/bin/bash
################################################################################
# DSI Test Execution Script - Optimized Version
# This script executes the DSI test sequence with configurable timing
# Sequence: DSI_Port_Setup.xml > DSI_Delay.xml > DSI_TTR_B0.xml
################################################################################

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default variables
PHY="cr"
PORT_SPEED_SET=25
TRAFFIC="ipsec"
LINERATE_TRAFFIC=65
LINERATE_SNAKE=0
LINERATE_PORT2X=65
DELAYS=20
PYTHON_CMD="python3"

# Timing configuration (can be adjusted for faster execution)
INITIAL_WAIT=25          # Wait before first SA command (original: 25s)
SA_WAIT=5                # Wait after SA before reading port rate (original: 5s)
QUAD_TRANSITION_WAIT=10  # Wait between quad transitions (original: 10s)
STOP_WAIT=10            # Wait before stopping traffic (original: 10s)
EXIT_WAIT=10            # Wait before exit (original: 10s)
CLEANUP_WAIT=10         # Wait before final cleanup (original: 10s)

# Working directories
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE_ROOT="$(dirname "$SCRIPT_DIR")"
BIN_DIR="$WORKSPACE_ROOT/bin"

# Log file
LOG_FILE="$BIN_DIR/dsi_test_$(date +%Y%m%d_%H%M%S).log"

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --phy) PHY="$2"; shift 2 ;;
        --port_speed_set) PORT_SPEED_SET="$2"; shift 2 ;;
        --traffic) TRAFFIC="$2"; shift 2 ;;
        --linerate_traffic) LINERATE_TRAFFIC="$2"; shift 2 ;;
        --linerate_snake) LINERATE_SNAKE="$2"; shift 2 ;;
        --linerate_port2x) LINERATE_PORT2X="$2"; shift 2 ;;
        --delays) DELAYS="$2"; shift 2 ;;
        --python) PYTHON_CMD="$2"; shift 2 ;;
        --initial_wait) INITIAL_WAIT="$2"; shift 2 ;;
        --sa_wait) SA_WAIT="$2"; shift 2 ;;
        --quad_wait) QUAD_TRANSITION_WAIT="$2"; shift 2 ;;
        --stop_wait) STOP_WAIT="$2"; shift 2 ;;
        --exit_wait) EXIT_WAIT="$2"; shift 2 ;;
        --cleanup_wait) CLEANUP_WAIT="$2"; shift 2 ;;
        --fast)
            # Fast mode - reduce all waits by 50%
            INITIAL_WAIT=15
            SA_WAIT=3
            QUAD_TRANSITION_WAIT=5
            STOP_WAIT=5
            EXIT_WAIT=5
            CLEANUP_WAIT=5
            shift
            ;;
        -h|--help)
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Test Configuration Options:"
            echo "  --phy <value>                PHY type (default: cr)"
            echo "  --port_speed_set <value>     Port speed: 10/25/50/100 (default: 25)"
            echo "  --traffic <value>            Traffic type: ipsec/clear (default: ipsec)"
            echo "  --linerate_traffic <value>   Line rate for traffic (default: 65)"
            echo "  --linerate_snake <value>     Line rate for snake (default: 0)"
            echo "  --linerate_port2x <value>    Line rate for port 2x (default: 65)"
            echo "  --delays <value>             Delay in seconds (default: 20)"
            echo "  --python <cmd>               Python command (default: python3)"
            echo ""
            echo "Timing Configuration Options:"
            echo "  --initial_wait <sec>         Wait before first SA (default: 25)"
            echo "  --sa_wait <sec>              Wait after SA before rate read (default: 5)"
            echo "  --quad_wait <sec>            Wait between quad transitions (default: 10)"
            echo "  --stop_wait <sec>            Wait before stopping traffic (default: 10)"
            echo "  --exit_wait <sec>            Wait before exit (default: 10)"
            echo "  --cleanup_wait <sec>         Wait before cleanup (default: 10)"
            echo "  --fast                       Use faster timing (50% reduction)"
            echo ""
            echo "  -h, --help                   Show this help message"
            exit 0
            ;;
        *)
            echo -e "${RED}Unknown option: $1${NC}"
            exit 1
            ;;
    esac
done

# Logging function
log() {
    echo -e "$1" | tee -a "$LOG_FILE"
}

# Function to print section headers
print_header() {
    log ""
    log "================================================================================"
    log "${GREEN}$1${NC}"
    log "================================================================================"
}

# Function to print step execution
print_step() {
    log "${YELLOW}>>> $1${NC}"
}

# Function to print info
print_info() {
    log "${BLUE}    $1${NC}"
}

# Function to check if previous command succeeded
check_status() {
    if [ $? -ne 0 ]; then
        log "${RED}Error: $1${NC}"
        if [ "$2" != "ignore" ]; then
            exit 1
        fi
    else
        log "${GREEN}Success: $1${NC}"
    fi
}

# Function to wait with countdown
wait_with_countdown() {
    local seconds=$1
    local message=$2
    print_info "Waiting $seconds seconds - $message"
    for ((i=seconds; i>0; i--)); do
        printf "\r${BLUE}    Time remaining: %02d seconds${NC}" "$i"
        sleep 1
    done
    printf "\r${BLUE}    Wait completed!                    ${NC}\n"
}

# Start test execution
log "================================================================================"
log "                    DSI Test Execution Script - Optimized"
log "================================================================================"
log "Configuration:"
log "  PHY Type:          $PHY"
log "  Port Speed:        $PORT_SPEED_SET"
log "  Traffic Type:      $TRAFFIC"
log "  Line Rate Traffic: $LINERATE_TRAFFIC"
log "  Line Rate Snake:   $LINERATE_SNAKE"
log "  Line Rate Port2x:  $LINERATE_PORT2X"
log "  Delays:            $DELAYS"
log ""
log "Timing Configuration:"
log "  Initial Wait:      $INITIAL_WAIT seconds"
log "  SA Wait:           $SA_WAIT seconds"
log "  Quad Transition:   $QUAD_TRANSITION_WAIT seconds"
log "  Stop Wait:         $STOP_WAIT seconds"
log "  Exit Wait:         $EXIT_WAIT seconds"
log "  Cleanup Wait:      $CLEANUP_WAIT seconds"
log ""
log "Estimated Total Time: ~$(( INITIAL_WAIT + (SA_WAIT * 5) + (QUAD_TRANSITION_WAIT * 8) + STOP_WAIT + EXIT_WAIT + CLEANUP_WAIT + DELAYS )) seconds"
log "================================================================================"
log "Log file: $LOG_FILE"
log "================================================================================"
log ""

# Get dynamic variables
print_header "PHASE 0: Setting Up Dynamic Variables"

print_step "Getting traffic type parameter..."
TRAFFIC_TYPE=$($PYTHON_CMD $SCRIPT_DIR/rate_validation/traffic_select.py -tr $TRAFFIC)
log "Traffic type parameter: '$TRAFFIC_TYPE'"

print_step "Getting port speed parameter..."
PORT_SPEED=$($PYTHON_CMD $SCRIPT_DIR/rate_validation/port_speed_select.py -ps $PORT_SPEED_SET)
log "Port speed parameter: '$PORT_SPEED'"

print_step "Getting PHY type parameter..."
PHY_TYPE=$($PYTHON_CMD $SCRIPT_DIR/rate_validation/phy_type_select.py -pt $PHY)
log "PHY type parameter: '$PHY_TYPE'"

# PHASE 1: DSI Port Setup
print_header "PHASE 1: DSI Port Setup (DSI_Port_Setup.xml)"

print_step "Copying inline configuration file..."
$PYTHON_CMD $SCRIPT_DIR/copy_conf.py -tt 'inline' >> "$LOG_FILE" 2>&1
check_status "Copy inline conf file completed"

print_step "Unloading DSI driver..."
/home/NAC/rdk/util/rmNAC.sh >> "$LOG_FILE" 2>&1
check_status "DSI driver unload completed"

print_step "Loading DSI driver..."
bash -c "source /home/NAC/rdk/iwa_rdk.env && /home/NAC/rdk/util/loadNAC.sh" >> "$LOG_FILE" 2>&1
check_status "DSI driver load completed"

# PHASE 2: DSI Delay
print_header "PHASE 2: DSI Delay (DSI_Delay.xml)"

print_step "Running delay script for $DELAYS seconds..."
$PYTHON_CMD $SCRIPT_DIR/run_delay.py -tdelay $DELAYS >> "$LOG_FILE" 2>&1
check_status "Delay script completed"

# PHASE 3: DSI TTR B0
print_header "PHASE 3: DSI TTR B0 Test (DSI_TTR_B0.xml)"

# Launch CLI master process in background
print_step "Launching CLI master process..."
$PYTHON_CMD $SCRIPT_DIR/cli_master_process.py >> "$LOG_FILE" 2>&1 &
CLI_MASTER_PID=$!
log "CLI master process launched (PID: $CLI_MASTER_PID)"
sleep 2

# Launch DSI test application
print_step "Setting up environment and launching DSI test application..."
bash -c "source /home/root/.profile" >> "$LOG_FILE" 2>&1
check_status "Hugepages setup completed"

print_step "Launching DSI test application with parameters:"
print_info "PHY Type: $PHY_TYPE"
print_info "Traffic Type: $TRAFFIC_TYPE"
print_info "Port Speed: $PORT_SPEED"

nohup bash -c "source /home/NAC/rdk/iwa_rdk.env && /home/NAC/app/crypto_inline_eth_tx_ppv/build_asic/ci_eth_tx --vdev=net_ice_dsi0,pci-bdf=f5:00.0,rxq=20,txq=20,ipsec_enable=1,cmpltnq=20 -- -p 4 -i -e -l 512 -b 32 -c ${PHY_TYPE} -s 0 ${TRAFFIC_TYPE} ${PORT_SPEED}" > $BIN_DIR/dsi_app.log 2>&1 &
DSI_APP_PID=$!
log "DSI test application launched (PID: $DSI_APP_PID)"

# Function to run quad test
run_quad_test() {
    local quad_num=$1
    local quad_cmd=$2

    if [ "$quad_num" != "0" ]; then
        print_step "Moving to $quad_cmd..."
        echo "$quad_cmd" > /tmp/ci_eth_tx_opt
        check_status "Move to $quad_cmd"
        wait_with_countdown $QUAD_TRANSITION_WAIT "for quad transition"
    else
        print_step "Starting Quad 0 test sequence..."
        wait_with_countdown $INITIAL_WAIT "for application initialization"
    fi

    print_step "Starting inline traffic (SA) for Quad $quad_num..."
    echo "sa" > /tmp/ci_eth_tx_opt
    check_status "Start inline traffic for Quad $quad_num"

    wait_with_countdown $SA_WAIT "for traffic to stabilize"

    print_step "Reading port rate for Quad $quad_num..."
    $PYTHON_CMD $SCRIPT_DIR/cli_processing_TTR.py -qd $quad_num >> "$LOG_FILE" 2>&1
    check_status "Read port rate for Quad $quad_num" "ignore"
}

# Run tests for all quads
run_quad_test 0 ""
run_quad_test 4 "x4"
run_quad_test 8 "x8"
run_quad_test 12 "x12"
run_quad_test 16 "x16"

# Stop traffic and exit
wait_with_countdown $STOP_WAIT "before stopping traffic"

print_step "Stopping inline traffic..."
echo "ta" > /tmp/ci_eth_tx_opt 2>&1 &
check_status "Stop inline traffic"

wait_with_countdown $EXIT_WAIT "before exit"

print_step "Exiting application..."
echo "e" > /tmp/ci_eth_tx_opt 2>&1 &
check_status "Execute exit command" "ignore"

print_step "Killing CLI process..."
$PYTHON_CMD $SCRIPT_DIR/process_kill.py >> "$LOG_FILE" 2>&1
check_status "Kill CLI process" "ignore"

wait_with_countdown $CLEANUP_WAIT "for final cleanup"

$PYTHON_CMD $SCRIPT_DIR/process_kill.py >> "$LOG_FILE" 2>&1
check_status "Final process kill" "ignore"

# PHASE 4: Log Validation
print_header "PHASE 4: Log Validation and Rate Validation"

# Function to validate quad
validate_quad() {
    local quad_num=$1

    print_step "Validating Quad $quad_num logs..."

    if [ -f "$BIN_DIR/ituff_logging_quad$quad_num.txt" ]; then
        $PYTHON_CMD $SCRIPT_DIR/DSI_sd.py $BIN_DIR/ituff_logging_quad$quad_num.txt >> "$LOG_FILE" 2>&1
        check_status "ITUFF processing for Quad $quad_num" "ignore"
    else
        log "${YELLOW}Warning: ITUFF log file for Quad $quad_num not found${NC}"
    fi

    $PYTHON_CMD $SCRIPT_DIR/rate_validation/rate_validate_TTR.py -qd $quad_num -tr $TRAFFIC -t_lr $LINERATE_TRAFFIC -s_lr $LINERATE_SNAKE -2x_lr $LINERATE_PORT2X -ps $PORT_SPEED_SET -pt $PHY >> "$LOG_FILE" 2>&1
    check_status "Rate validation for Quad $quad_num"
}

# Validate all quads
validate_quad 0
validate_quad 4
validate_quad 8
validate_quad 12
validate_quad 16

# Final Summary
print_header "Test Execution Completed"
log "${GREEN}All DSI test phases have been executed successfully!${NC}"
log ""
log "Test Summary:"
log "  Phases executed:"
log "    1. DSI Port Setup"
log "    2. DSI Delay ($DELAYS seconds)"
log "    3. DSI TTR B0 Test (5 quads: 0, 4, 8, 12, 16)"
log "    4. Log Validation and Rate Validation"
log ""
log "Output files:"
log "  Test log:        $LOG_FILE"
log "  Application log: $BIN_DIR/dsi_app.log"
log "  ITUFF logs:      $BIN_DIR/ituff_logging_quad*.txt"
log "================================================================================"

exit 0
